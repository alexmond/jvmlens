#!/usr/bin/env bash
# Deterministic replay of CAPTURED (golden) Claude responses for the launch demo GIF —
# so it re-renders OFFLINE with no live API call. The real one-time captures live one dir up:
#   claude-with-jvmlens.txt  — Claude's answer given the jvmlens summary (it nails the fix)
#   claude-too-long.txt      — Claude's real "prompt too long" error on the raw JFR dump
# render.sh puts this bin/ first on PATH so `claude` in the tape resolves here. See ../README.md.
here="$(cd "$(dirname "$0")" && pwd)"
demo="$(dirname "$here")"
input="$(cat)"                         # consume the piped stdin (jvmlens summary OR raw dump)
if [ "${#input}" -gt 100000 ]; then    # a raw `jfr print` dump overflows the context window
	cat "$demo/claude-too-long.txt" >&2
	exit 1
fi
cat "$demo/claude-with-jvmlens.txt"
